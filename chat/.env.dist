# Go
GIN_MODE=debug

# Database
POSTGRES_URL=postgres://postgres:postgres@chatterbox-postgres:5432/chat_db?sslmode=disable
MIGRATIONS_PATH=/srv/migrations

# HTTP
HTTP_SERVER_PORT=80

# Queue
RABBITMQ_URL=amqp://guest:guest@chatterbox-rabbitmq:5672/
RABBITMQ_EXCHANGE=chat_events

# Security
SECURITY_PUBLIC_KEY_PATH=/srv/certs/public.pem

# JWT
JWT_ISSUER=chatterbox-user-service
