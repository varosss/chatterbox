# Go
GIN_MODE=debug

# Database
POSTGRES_URL=postgres://postgres:postgres@chatterbox-postgres:5432/user_db?sslmode=disable
MIGRATIONS_PATH=/srv/migrations

# HTTP
HTTP_SERVER_PORT=80

# Security
SECURITY_PUBLIC_KEY_PATH=/srv/certs/public.pem
SECURITY_PRIVATE_KEY_PATH=/srv/certs/private.pem
SECURITY_HASH_COST=10

# JWT
JWT_ISSUER=chatterbox-user-service
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
